## Error Handling | معالجة الأخطاء

```python
# integrations/gemini_service.py

import google.generativeai as genai
import json
import logging

logger = logging.getLogger(__name__)

def call_gemini(prompt: str, config_key: str = "flash", image=None) -> dict | str:
    """
    Wrapper for all Gemini API calls.
    Returns parsed JSON dict for structured prompts, or raw string for text prompts.
    """
    try:
        model = genai.GenerativeModel(GEMINI_CONFIG[config_key]["model"])
        
        contents = [image, prompt] if image else [prompt]
        
        response = model.generate_content(
            contents,
            generation_config={
                "temperature": GEMINI_CONFIG[config_key]["temperature"],
                "max_output_tokens": GEMINI_CONFIG[config_key]["max_output_tokens"],
            }
        )
        
        text = response.text.strip()
        
        # Try JSON parse if response looks like JSON
        if text.startswith("{") or text.startswith("["):
            # Strip markdown fences if present
            text = text.replace("```json", "").replace("```", "").strip()
            try:
                return json.loads(text)
            except json.JSONDecodeError:
                # Retry once with explicit JSON instruction
                retry_prompt = prompt + "\n\nIMPORTANT: Return ONLY valid JSON. No other text."
                retry_response = model.generate_content([retry_prompt])
                retry_text = retry_response.text.strip().replace("```json", "").replace("```", "").strip()
                return json.loads(retry_text)
        
        return text
        
    except Exception as e:
        logger.error(f"Gemini API error for config '{config_key}': {e}")
        raise
```

