# ============================================================
# Bayt Alebaa — PDC Backend Environment Variables
# ============================================================
# Copy this file to .env and fill in the values

# Django
SECRET_KEY=your-django-secret-key-here-min-50-chars
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL)
DATABASE_URL=postgresql://pdc_user:pdc_password@localhost:5432/pdc_db
# OR individual settings:
DB_NAME=pdc_db
DB_USER=pdc_user
DB_PASSWORD=pdc_password
DB_HOST=localhost
DB_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0

# Cloudflare R2 (S3-compatible)
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=bayt-alebaa-pdc
R2_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://your-custom-domain.com

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key

# Remove.bg (Background Removal)
REMOVEBG_API_KEY=your-removebg-api-key

# SAP Integration (optional)
SAP_BASE_URL=https://your-sap-instance.com
SAP_USERNAME=sap_user
SAP_PASSWORD=sap_password

# JWT Settings
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Email (for notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@baytalebaa.com
EMAIL_HOST_PASSWORD=your-email-password
